@model IEnumerable<UrlHealthMonitor.Models.MonitoredUrl>

@{
    ViewData["Title"] = "Monitored URLs";
}

<h2>Monitored URLs</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>URL</th>
            <th>Interval</th>
            <th>Health</th>
            <th>Down Duration</th>
            <th>Last Updated</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Name</td>

            <td>
                <a href="@item.Url" target="_blank">@item.Url</a>
            </td>

            <td>@item.IntervalSeconds sec</td>

            <td>
                @if (item.Health == "Healthy")
                {
                    <span class="badge bg-success">Healthy</span>
                }
                else if (item.Health == "Down")
                {
                    <span class="badge bg-danger">Down</span>
                }
                else
                {
                    <span class="badge bg-secondary">Unknown</span>
                }
            </td>

            <td>
                @if (item.Health == "Down" && item.DownSince != null)
                {
                    var duration = DateTime.UtcNow - item.DownSince.Value;
                    <span class="text-danger fw-bold">
                        @($"{(int)duration.TotalMinutes}m {duration.Seconds}s")
                    </span>
                }
                else
                {
                    <span>-</span>
                }
            </td>

            <td>@item.LastUpdated</td>

            <td>
                <a asp-action="Edit"
                   asp-route-id="@item.Id"
                   class="btn btn-sm btn-warning">
                    Edit
                </a>

                <a asp-action="Delete"
                   asp-route-id="@item.Id"
                   class="btn btn-sm btn-danger">
                    Delete
                </a>
            </td>
        </tr>
}
    </tbody>
</table>

<script>
    // Auto refresh every 10 seconds
    setInterval(function () {
        location.reload();
    }, 10000);
</script>



